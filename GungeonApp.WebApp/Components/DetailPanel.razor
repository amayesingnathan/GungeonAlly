@inject InventoryState State
@inject IGungeonService GungeonDB

<div class="item-heading centre">
    @{
        string name = State.CurrentItemSelected?.ItemName ?? string.Empty;
    }
    @name
</div>
<div class="item-image-detail centre">
    <div class="image-frame centre">
        <InventoryItem Context="@State.CurrentItemSelected" Scale="8" Selectable="false"/>
    </div>
    <div class="quote-label centre">
    @{
        string quote = State.CurrentItemSelected?.Quote ?? string.Empty;
    }
    @quote
    </div>
    <div class="itemtype-label centre">
        @{
            string type = string.Empty;
            ItemBase? item = State.CurrentItemBaseSelected;

            if (item != null)
            {
                if (item is Gun)
                {
                    type = State.CurrentGunSelected?.GunType ?? string.Empty;
                }
                else
                {
                    type = State.CurrentItemSelected?.ItemType ?? string.Empty;
                }
            }
        }
    @type
    </div>
</div>
<div class="description-label">
</div>
<div style="height: 8%; min-height: 8%">
</div>

@code {
    [Inject]
    public IRefreshService RefreshService { get; set; }

    protected override void OnInitialized()
    {
        RefreshService.RefreshRequested += OnRefresh;
    }

    private async Task OnRefresh()
    {
        StateHasChanged();
        await Task.CompletedTask;
    }
}
